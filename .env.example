# ==================== AI CONFIGURATION ====================
# Provider: openai-compatible (Groq or Claude)
AI_PROVIDER=openai-compatible

# Model: llama-3.1-8b-instant (Groq) or claude-3-haiku (Anthropic)
AI_MODEL=llama-3.1-8b-instant

# Base URL
# Groq: https://api.groq.com/openai/v1
# Anthropic: https://api.anthropic.com/v1
AI_BASE_URL=https://api.groq.com/openai/v1

# API Key for your AI provider
AI_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# ==================== TELEGRAM BOT ====================
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Chat ID to notify agents (usually your admin chat ID)
AGENT_NOTIFY_CHAT_ID=123456789

# Optional: Webhook to notify external systems
AGENT_NOTIFY_WEBHOOK_URL=

# ==================== MEDIA URLS ====================
# Plan images - must be publicly accessible
FIBER_PLAN_MEDIA_URL=https://via.placeholder.com/800x600?text=Planes+Fibra
WIRELESS_PLAN_MEDIA_URL=https://via.placeholder.com/800x600?text=Planes+Inalambricos

# ==================== ADMIN PANEL ====================
# Password to access admin dashboard
# IMPORTANT: Change this in production!
ADMIN_PASSWORD=leon123

# Admin token (used internally)
ADMIN_TOKEN=temp-token

# ==================== OPTIONAL ====================
# Contact number shown to users
LEON_CONTACT_NUMBER=9511603125

# Wisphub API URL (for network status checks)
WISPHUB_API_URL=

# Server port
PORT=3000

