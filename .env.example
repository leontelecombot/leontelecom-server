# ==================== AI CONFIGURATION ====================
# Provider: 'anthropic' para Claude (recomendado) o 'openai-compatible' para Groq
AI_PROVIDER=anthropic

# Model de Claude (recomendado) o Groq
AI_MODEL=claude-haiku-4-5-20251001

# Base URL - solo se usa si AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.groq.com/openai/v1

# API Key de Anthropic (Claude) o Groq
AI_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# ==================== WHATSAPP CLOUD API (Meta) ====================
# Obtener en: developers.facebook.com → Tu App → WhatsApp → Getting started

# Phone Number ID (aparece en la sección "Getting started" de WhatsApp en tu app)
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE

# Access Token (Permanent token, o System User token)
WHATSAPP_ACCESS_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN_HERE

# Verify Token - elige cualquier texto secreto para verificar el webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=leontelecom-verify

# ==================== TELEGRAM BOT (opcional, para notificaciones internas) ====================
# Si tienes un chat de Telegram para recibir alertas de agentes
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Chat ID de Telegram donde se notifican las solicitudes de asesor
AGENT_NOTIFY_CHAT_ID=123456789

# Webhook alternativo para notificaciones (ej: n8n, Make, Zapier)
AGENT_NOTIFY_WEBHOOK_URL=

# ==================== MEDIA URLS ====================
# Imágenes de planes - deben ser URLs públicas
FIBER_PLAN_MEDIA_URL=https://drive.google.com/uc?export=view&id=13ho0x5wUS_Uus5MhJrNq0blMOzk39Ffn
WIRELESS_PLAN_MEDIA_URL=https://drive.google.com/uc?export=view&id=1Zc5Xg8W4S0izF088yA5k32WyI8i83sFO

# ==================== ADMIN PANEL ====================
# Contraseña para acceder al panel de administración
ADMIN_PASSWORD=leon123

# ==================== OPTIONAL ====================
# Número de contacto mostrado a usuarios
LEON_CONTACT_NUMBER=9511603125

# URL de Wisphub API (para verificación de estado de red)
WISPHUB_API_URL=

# Puerto del servidor
PORT=3000
