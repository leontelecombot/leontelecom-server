# Proveedor de IA
# Recomendado para demo privada/local: ollama
# Otras opciones: openai-compatible
AI_PROVIDER=ollama

# Modelo de IA
# Ollama: llama3.1, llama3.2, mistral, qwen2.5
# OpenAI-compatible: el modelo que exponga tu proveedor
AI_MODEL=llama3.1

# Base URL de la IA
# Ollama local: http://127.0.0.1:11434
# OpenAI-compatible: https://api.tu-proveedor.com/v1
AI_BASE_URL=http://127.0.0.1:11434

# API Key para proveedores compatibles con OpenAI
AI_API_KEY=

# Timeout en milisegundos para la IA
AI_TIMEOUT_MS=25000

# Si está en true, usa respuesta local de respaldo cuando la IA no está disponible
DEMO_MODE=true

# URL publica de las imagenes de planes
# Deben ser accesibles desde internet para que Twilio las adjunte en WhatsApp.
# Ejemplos:
# - Placeholder (para testing): https://via.placeholder.com/800x600?text=Planes
# - GitHub Pages: https://tuusuario.github.io/images/fiber.png
# - Cloudflare R2: https://tucdn.example.com/fiber.png
# - Imgur: https://i.imgur.com/xxxxx.png
# Puedes crear imágenes y subirlas a GitHub Pages gratis: crea repo, rama gh-pages, sube images/ folder
FIBER_PLAN_MEDIA_URL=https://via.placeholder.com/800x600?text=Planes+Fibra+Optica+Leon+Telecom
WIRELESS_PLAN_MEDIA_URL=https://via.placeholder.com/800x600?text=Planes+Inalambricos+Leon+Telecom

# Numero temporal de demostracion que se muestra al cliente
LEON_CONTACT_NUMBER=9511603125

# Credenciales de Twilio
# Las encuentras en: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número de WhatsApp de Twilio
# Sandbox: +14155238886
# Producción: el número real que aprobó Meta (ej. +521XXXXXXXXXX)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
